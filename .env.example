# ── Anthropic (Claude API) ─────────────────────────────────────────────
# https://platform.claude.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 요약·인사이트 생성 모델 (기본값: claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# ── Gmail SMTP (메일 발송) ──────────────────────────────────────────────
# 보내는 Gmail 계정 주소
GMAIL_USER=your-account@gmail.com
# Gmail "앱 비밀번호" (일반 로그인 비밀번호 아님)
#  → Google 계정 > 보안 > 2단계 인증 활성화 후 "앱 비밀번호" 발급
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 발신자 표시 이름 (선택)
MAIL_FROM_NAME=범한그룹 AI 인사이트

# ── 자동 발송 스케줄 (--schedule 모드) ─────────────────────────────────
# 매일 발송 시각 (HH:MM, 24시간제)
SEND_TIME=08:00
# 시간대 (IANA tz)
SEND_TIMEZONE=Asia/Seoul
# (선택) cron 식으로 직접 지정 — 설정 시 SEND_TIME 보다 우선
#  예) 평일 오전 7시 30분: 30 7 * * 1-5
# SEND_CRON=0 8 * * *
